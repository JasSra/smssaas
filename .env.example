# ─── Required ─────────────────────────────────────────────────────────────────

# Shared secret for /admin/* and /worker/* endpoints. inboxr-cloud uses this as
# SMS_ADMIN_KEY too — make them match if you run the cloud.
ADMIN_KEY=replace-me-with-openssl-rand-hex-32

# Shared secret the Android APK presents to the API. Must match the
# DEVICE_SECRET extra you pass to the APK at install / launch time.
DEVICE_SECRET=replace-me-with-openssl-rand-hex-16


# ─── Inboxr-cloud webhook (optional but typical) ──────────────────────────────
# When inbound SMS arrives we fire a POST to this URL so the cloud can route
# the message into the right tenant inbox. Leave blank for standalone use.

CLOUD_WEBHOOK_URL=
CLOUD_WEBHOOK_KEY=


# ─── Redis time-series + hot indices (optional) ───────────────────────────────
# Persists phone diagnostics + recent activity feeds. Best-effort — never
# blocks an API request.

REDIS_URL=


# ─── Voice / IVR — TTS + AI flow generation (optional) ────────────────────────

# OpenAI: drives `tts-1` voices (alloy / echo / fable / onyx / nova / shimmer)
# for IVR `play` nodes. Falls back to local pyttsx3 if missing.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1

# Anthropic: powers the "Generate flow from description" buttons.
# Without a key the AI Generate buttons return 502; TTS still works.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6


# ─── Whisper (transcription) ──────────────────────────────────────────────────
# Sizes: tiny / base / small / medium / large. small is the sweet spot for
# voicemail / call quality on CPU.
WHISPER_MODEL=small


# ─── Stripe (optional, for billing self-host customers) ───────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
